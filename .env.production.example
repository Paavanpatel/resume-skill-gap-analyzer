# ==============================================================
# Resume Skill Gap Analyzer — Production Environment Template
#
# Copy to .env.production and fill in ALL values before deploying.
# DO NOT commit this file with real secrets.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ==============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=resume-skill-gap-analyzer
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# ── Backend (FastAPI) ────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
# 64-char random hex string — MUST be unique and secret
SECRET_KEY=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
ALLOWED_ORIGINS=https://yourdomain.com

# ── Frontend (Next.js — build-time vars) ─────────────────────
# These are baked in at build time via Dockerfile.prod ARGs.
# In production, Nginx proxies /api/* → backend, so relative paths work.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=/ws
# Used by next-sitemap to generate the sitemap's absolute URLs
SITE_URL=https://yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=skill_gap_analyzer
POSTGRES_USER=rsga_app
POSTGRES_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE
# IMPORTANT: Docker .env files do NOT support ${VAR} interpolation.
# Hardcode the full URL with your actual credentials:
DATABASE_URL=postgresql+asyncpg://rsga_app:GENERATE_A_STRONG_PASSWORD_HERE@postgres:5432/skill_gap_analyzer

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE
# Hardcode your actual Redis password:
REDIS_URL=redis://:GENERATE_A_STRONG_PASSWORD_HERE@redis:6379/0

# ── AI / LLM ────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-YOUR_REAL_KEY_HERE
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

AI_FALLBACK_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-YOUR_REAL_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── File Storage ─────────────────────────────────────────────
# Use S3 in production. Set STORAGE_BACKEND=s3 and fill in the vars below.
# For AWS S3: leave S3_ENDPOINT_URL blank.
# For MinIO / self-hosted: set S3_ENDPOINT_URL to your MinIO URL.
STORAGE_BACKEND=s3
STORAGE_LOCAL_PATH=/app/storage
S3_BUCKET=rsga-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_ENDPOINT_URL=
S3_PRESIGNED_URL_EXPIRY_SECONDS=300

# ── JWT Auth ─────────────────────────────────────────────────
# Another 64-char random hex string — different from SECRET_KEY
JWT_SECRET_KEY=GENERATE_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_ANALYSIS_PER_HOUR=10

# ── Celery (Task Queue + Beat Scheduler) ─────────────────────
# Hardcode your actual Redis password in these URLs:
CELERY_BROKER_URL=redis://:GENERATE_A_STRONG_PASSWORD_HERE@redis:6379/1
CELERY_RESULT_BACKEND=redis://:GENERATE_A_STRONG_PASSWORD_HERE@redis:6379/2

# ── Celery Beat — Backup Settings ───────────────────────────
# Number of daily backups to keep before pruning older ones
BACKUP_RETENTION_COUNT=7
# Absolute path inside the container where dumps are written
BACKUP_DIR=/app/storage/backups

# ── File Upload Limits ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ── Email (SMTP) ─────────────────────────────────────────────
# Set email_backend=smtp for production (console only logs to stdout).
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD_HERE
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=SkillGap
SMTP_USE_TLS=true

# ── Stripe Billing ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID
STRIPE_ENTERPRISE_PRICE_ID=price_YOUR_ENTERPRISE_PRICE_ID
# URL that Stripe redirects to after checkout (must match ALLOWED_ORIGINS)
FRONTEND_URL=https://yourdomain.com
