# ============================================================
# Resume Skill Gap Analyzer - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=resume-skill-gap-analyzer
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Backend (FastAPI) ────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skill_gap_analyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ── AI / LLM ────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Fallback provider
AI_FALLBACK_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── File Storage ─────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# Switch to S3 or MinIO: set STORAGE_BACKEND=s3 and fill in the vars below.
# MinIO (local dev):  S3_ENDPOINT_URL=http://minio:9000, keys = minioadmin/minioadmin
# AWS S3 (prod):      leave S3_ENDPOINT_URL blank, use real IAM credentials
# STORAGE_BACKEND=s3
# S3_BUCKET=rsga-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_ENDPOINT_URL=http://minio:9000
# S3_PRESIGNED_URL_EXPIRY_SECONDS=300



# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_ANALYSIS_PER_HOUR=10

# ── Celery (Task Queue) ─────────────────────────────────────
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ── File Upload Limits ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
